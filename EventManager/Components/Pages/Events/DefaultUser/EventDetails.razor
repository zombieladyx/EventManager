@page "/events/{Id:int}"
@using Microsoft.AspNetCore.Authorization
@using EventManager.Data
@rendermode InteractiveServer
@inject IEventService EventService
@inject NavigationManager Navigation

@if (ev == null)
{
    <div class="alert alert-info">Ładowanie szczegółów eventu...</div>
}
else if (ev.EVENT_ID == 0)
{
    <div class="alert alert-warning">Event nie znaleziony.</div>
}
else
{
    <div class="card">
        <div class="card-header">
            <h3>@ev.SHORT_DESC</h3>
        </div>
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-3">Opis:</dt>
                <dd class="col-sm-9">@ev.DESCRIPTION</dd>
                
                <dt class="col-sm-3">Limit miejsc:</dt>
                <dd class="col-sm-9">@ev.SPACE_LIMIT</dd>
                
                <dt class="col-sm-3">Zajęte miejsca:</dt>
                <dd class="col-sm-9">@ev.CURR_SPACE <span class="badge @(GetBadgeClass())">@GetOccupancyPercent()%</span></dd>
                
                <dt class="col-sm-3">Data eventu:</dt>
                <dd class="col-sm-9">@ev.EVENT_DATE.ToString("dd.MM.yyyy HH:mm")</dd>
            </dl>
        </div>
        <div class="card-footer">
            <button class="btn btn-secondary me-2" @onclick="BackToList">Powrót do listy</button>
        </div>
    </div>
}

@code {
    [Parameter] public int Id { get; set; }
    private Event? ev;

    protected override async Task OnInitializedAsync()
    {
        ev = await EventService.GetEventAsync(Id);
    }

    private string GetBadgeClass()
    {
        if (ev == null) return "";
        var percent = (double)ev.CURR_SPACE / ev.SPACE_LIMIT * 100;
        return percent > 90 ? "bg-danger" : percent > 70 ? "bg-warning" : "bg-success";
    }

    private string GetOccupancyPercent()
    {
        if (ev == null) return "";
        return Math.Round((double)ev.CURR_SPACE / ev.SPACE_LIMIT * 100).ToString();
    }

    private void BackToList() => Navigation.NavigateTo("/events");
    
}