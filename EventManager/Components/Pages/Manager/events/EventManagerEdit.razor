@page "/eventsManagerEdit/{Id}"
@using EventManager.Data
@rendermode InteractiveServer
@inject IEventService EventService
@inject NavigationManager Navigation

@* Nagłówek strony z formularzem edycji wydarzenia *@
<h3>Edit Event</h3>

@if (editEvent == null)
{
    @* Komunikat podczas pobierania danych *@
    <p>Loading event data...</p>
}
else
{
    @* Formularz edycji istniejącego wydarzenia *@
    <EditForm Model="editEvent" OnValidSubmit="ShowConfirmPopup">
        <DataAnnotationsValidator />
        <ValidationSummary />

        @* Id eventu tylko do odczytu, aby nie zmieniać klucza głównego *@
        <div class="mb-3">
            <label class="form-label">Event ID (6 characters)</label>
            <InputText @bind-Value="editEvent.EVENT_ID" class="form-control" disabled />
        </div>

        @* Pole na krótki opis *@
        <div class="mb-3">
            <label class="form-label">Short description</label>
            <InputText @bind-Value="editEvent.SHORT_DESC" class="form-control" />
        </div>

        @* Pole na długi opis *@
        <div class="mb-3">
            <label class="form-label">Description</label>
            <InputTextArea @bind-Value="editEvent.DESCRIPTION" class="form-control" />
        </div>

        @* Pole na limit miejsc *@
        <div class="mb-3">
            <label class="form-label">Seat limit</label>
            <InputNumber @bind-Value="editEvent.SPACE_LIMIT" class="form-control" />
        </div>

        @* Pole wyboru daty wydarzenia *@
        <div class="mb-3">
            <label class="form-label">Event date</label>
            <InputDate @bind-Value="eventDate" class="form-control" />
        </div>

        @* Przyciski akcji formularza *@
        <button type="submit" class="btn btn-primary">Save</button>
        <button type="button" class="btn btn-secondary ms-2" @onclick="Cancel">Cancel</button>
    </EditForm>
}

@* Popup z potwierdzeniem zapisu zmian *@
@if (showConfirmPopup)
{
    <div class="popup-overlay">
        <div class="popup-card">
            <div class="popup-header">
                <div class="popup-title-wrap">
                    <span class="popup-icon">⚠️</span>
                    <span class="popup-title">Confirm Changes</span>
                </div>
                <button type="button" class="popup-close" @onclick="HideConfirmPopup">×</button>
            </div>

            <div class="popup-body">
                <p>Are you sure you want to save the changes?</p>
            </div>

            <div class="popup-footer">
                <button class="btn btn-outline-secondary" @onclick="HideConfirmPopup">Cancel</button>
                <button class="btn btn-primary" @onclick="ConfirmSaveAsync">Save</button>
            </div>
        </div>
    </div>
}

@code {
    // Parametr pobierany z adresu URL
    [Parameter] public string Id { get; set; } = string.Empty;

    // Obiekt edytowanego wydarzenia
    private Event? editEvent;

    // Tymczasowa zmienna daty dla InputDate
    private DateTime eventDate = DateTime.Today;

    // Flaga widoczności popupu potwierdzającego zapis
    private bool showConfirmPopup = false;

    // Pobranie danych wydarzenia po załadowaniu strony
    protected override async Task OnInitializedAsync()
    {
        editEvent = await EventService.GetEventAsync(Id);

        if (editEvent != null)
        {
            eventDate = editEvent.EVENT_DATE.ToDateTime(TimeOnly.MinValue);
        }
    }

    // Pokazuje popup potwierdzenia zapisu
    private void ShowConfirmPopup()
    {
        showConfirmPopup = true;
    }

    // Ukrywa popup potwierdzenia zapisu
    private void HideConfirmPopup()
    {
        showConfirmPopup = false;
    }

    // Zapisuje zmiany po potwierdzeniu użytkownika
    private async Task ConfirmSaveAsync()
    {
        if (editEvent == null)
            return;

        editEvent.EVENT_DATE = DateOnly.FromDateTime(eventDate);
        await EventService.UpdateEventAsync(editEvent);
        Navigation.NavigateTo("/eventsManager");
    }

    // Anuluje edycję i wraca do listy
    private void Cancel()
    {
        Navigation.NavigateTo("/eventsManager");
    }
}