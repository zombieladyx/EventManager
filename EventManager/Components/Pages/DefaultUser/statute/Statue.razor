@page "/statute"
@using Microsoft.AspNetCore.Authorization
@using EventManager.Data
@rendermode InteractiveServer
@inject UserService UserService
@inject NavigationManager Navigation
@inject TranslatorService TranslatorService
@inject LanguageStateService LanguageState

@attribute [Authorize(Roles = "DefaultUser")]
@implements IDisposable

@* Nagłówek strony z regulaminem *@
<h3>@titleText</h3>

@* Jeżeli dane jeszcze się ładują, pokazujemy komunikat o ładowaniu *@
@if (isLoading)
{
    <p>@loadingText</p>
}
else
{
    <div class="terms-container">
        @* Krótki opis wyjaśniający użytkownikowi cel strony *@
        <p>@introText</p>

        @* Lista zasad, które użytkownik musi zaakceptować, aby korzystać z aplikacji *@
        <ol>
            @foreach (var item in termsItems)
            {
                <li>@item</li>
            }
        </ol>

        @* Jeśli regulamin został już wcześniej zaakceptowany, pokazujemy tylko komunikat *@
        @if (alreadyAccepted)
        {
            <div class="alert alert-success mt-4">
                @alreadyAcceptedText
            </div>
        }
        else
        {
            @* Checkbox, którym użytkownik zaznacza akceptację regulaminu *@
            <div class="form-check mt-4">
                <input class="form-check-input" type="checkbox" id="acceptTerms" @bind="isAccepted" />
                <label class="form-check-label" for="acceptTerms">
                    @acceptLabelText
                </label>
            </div>

            @* Przycisk zapisujący akceptację regulaminu do bazy danych *@
            <div class="mt-4">
                <button class="btn btn-primary" @onclick="SaveAcceptance" disabled="@isSaving">
                    @acceptButtonText
                </button>
            </div>
        }

        @* Komunikat informacyjny lub błędu, jeśli został ustawiony *@
        @if (!string.IsNullOrWhiteSpace(message))
        {
            <div class="alert alert-info mt-3">
                @message
            </div>
        }
    </div>
}

@code {
    // Flaga przechowująca stan checkboxa, czyli czy użytkownik zaznaczył akceptację regulaminu.
    private bool isAccepted = false;

    // Flaga informująca, czy aktualny użytkownik ma już zapisane zaakceptowanie regulaminu w bazie.
    private bool alreadyAccepted = false;

    // Flaga odpowiedzialna za stan ładowania strony.
    // Dopóki dane nie zostaną pobrane z serwisu, widok pokazuje komunikat o ładowaniu.
    private bool isLoading = true;

    // Flaga blokująca wielokrotne kliknięcie przycisku podczas zapisywania danych do bazy.
    private bool isSaving = false;

    // Zmienna przechowująca komunikat dla użytkownika.
    private string message = string.Empty;

    // E-mail aktualnie zalogowanego użytkownika pobrany z serwisu.
    // Na podstawie tej wartości sprawdzamy w bazie, czy ten konkretny user zaakceptował regulamin.
    private string currentUserId = string.Empty;

    // Tekst nagłówka strony.
    private string titleText = "Terms and Conditions";

    // Tekst wyświetlany podczas ładowania strony.
    private string loadingText = "Loading...";

    // Tekst wstępu do regulaminu.
    private string introText = "By using this application, you agree to follow the terms and conditions below.";

    // Komunikat wyświetlany, gdy użytkownik już wcześniej zaakceptował regulamin.
    private string alreadyAcceptedText = "You have already accepted the terms and conditions.";

    // Tekst etykiety checkboxa akceptacji regulaminu.
    private string acceptLabelText = "I accept the terms and conditions and want to proceed to the events list.";

    // Tekst przycisku zapisu akceptacji.
    private string acceptButtonText = "Accept and Continue";

    // Lista punktów regulaminu, które będą wyświetlane użytkownikowi.
    private List<string> termsItems = new()
    {
        "The user may use the application only for lawful purposes.",
        "It is forbidden to abuse the event registration system.",
        "The user must not provide false data during registration.",
        "The administrator has the right to remove an account in case of rule violation.",
        "The user agrees that event-related data may be processed to support the application."
    };

    // Metoda wykonywana podczas inicjalizacji komponentu.
    // Pobiera e-mail zalogowanego użytkownika, sprawdza akceptację regulaminu
    // oraz wykonuje pierwsze tłumaczenie treści na aktualnie wybrany język.
    protected override async Task OnInitializedAsync()
    {
        // Subskrypcja zdarzenia zmiany języka.
        // Dzięki temu komponent automatycznie odświeży treść po zmianie języka w MainLayout.
        LanguageState.OnLanguageChanged += HandleLanguageChanged;

        // Pobranie adresu e-mail aktualnie zalogowanego użytkownika.
        currentUserId = UserService.GetEmail();

        // Jeśli nie udało się pobrać e-maila, nie można sprawdzić stanu akceptacji.
        if (string.IsNullOrWhiteSpace(currentUserId))
        {
            message = "Unable to identify the current user.";
            isLoading = false;
            return;
        }

        // Pobranie z bazy wartości pola TERMS_ACCEPTED dla aktualnego użytkownika.
        // Dzięki temu wiemy, czy user już wcześniej zaakceptował regulamin.
        var termsValue = await UserService.GetTermsAcceptanceAsync(currentUserId);

        // Sprawdzenie, czy regulamin został już zaakceptowany.
        alreadyAccepted = termsValue == "YES";

        // Wykonanie pierwszego tłumaczenia całej zawartości strony na aktualny język.
        await TranslateAllAsync();

        // Zakończenie stanu ładowania — widok może zostać wyrenderowany.
        isLoading = false;
    }

    // Metoda wywoływana automatycznie po zmianie języka w MainLayout.
    // Tłumaczy wszystkie teksty strony na nowy język i odświeża widok.
    private async void HandleLanguageChanged()
    {
        await TranslateAllAsync();
        await InvokeAsync(StateHasChanged);
    }

    // Tłumaczy wszystkie teksty widoczne na stronie na język wybrany przez użytkownika.
    private async Task TranslateAllAsync()
    {
        // Język źródłowy treści zapisanych w kodzie.
        var sourceLanguage = "en";

        // Język docelowy pobierany z globalnego stanu aplikacji.
        var targetLanguage = LanguageState.CurrentLanguage;

        // Tłumaczenie tekstów statycznych strony.
        titleText = await TranslatorService.TranslateAsync("Terms and Conditions", sourceLanguage, targetLanguage);
        loadingText = await TranslatorService.TranslateAsync("Loading...", sourceLanguage, targetLanguage);
        introText = await TranslatorService.TranslateAsync("By using this application, you agree to follow the terms and conditions below.", sourceLanguage, targetLanguage);
        alreadyAcceptedText = await TranslatorService.TranslateAsync("You have already accepted the terms and conditions.", sourceLanguage, targetLanguage);
        acceptLabelText = await TranslatorService.TranslateAsync("I accept the terms and conditions and want to proceed to the events list.", sourceLanguage, targetLanguage);
        acceptButtonText = await TranslatorService.TranslateAsync("Accept and Continue", sourceLanguage, targetLanguage);

        // Tłumaczenie wszystkich punktów regulaminu z listy.
        var translatedItems = new List<string>();

        foreach (var item in new[]
        {
            "The user may use the application only for lawful purposes.",
            "It is forbidden to abuse the event registration system.",
            "The user must not provide false data during registration.",
            "The administrator has the right to remove an account in case of rule violation.",
            "The user agrees that event-related data may be processed to support the application."
        })
        {
            translatedItems.Add(await TranslatorService.TranslateAsync(item, sourceLanguage, targetLanguage));
        }

        termsItems = translatedItems;

        // Jeśli komunikat jest ustawiony, tłumaczymy go również na wybrany język.
        if (!string.IsNullOrWhiteSpace(message))
        {
            message = await TranslatorService.TranslateAsync(message, sourceLanguage, targetLanguage);
        }
    }

    // Metoda zapisująca akceptację regulaminu do bazy danych.
    // Uruchamiana po kliknięciu przycisku "Accept and Continue".
    private async Task SaveAcceptance()
    {
        // Jeżeli użytkownik nie zaznaczył checkboxa, nie pozwalamy zapisać zgody.
        if (!isAccepted)
        {
            message = await TranslatorService.TranslateAsync(
                "You must accept the terms and conditions to continue.",
                "en",
                LanguageState.CurrentLanguage);
            return;
        }

        // Ponowna kontrola, czy znamy aktualnego użytkownika.
        // Bez tego nie wiadomo, do którego rekordu w bazie zapisać zgodę.
        if (string.IsNullOrWhiteSpace(currentUserId))
        {
            message = await TranslatorService.TranslateAsync(
                "Unable to identify the current user.",
                "en",
                LanguageState.CurrentLanguage);
            return;
        }

        try
        {
            // Ustawienie flagi blokującej kolejne kliknięcia podczas wykonywania zapisu.
            isSaving = true;

            // Aktualizacja pola TERMS_ACCEPTED w bazie danych na wartość "YES".
            // Dzięki temu przy następnym wejściu na stronę system rozpozna, że regulamin został zaakceptowany.
            await UserService.UpdateTermsAcceptanceAsync(currentUserId, "YES");

            // Komunikat potwierdzający poprawny zapis akceptacji.
            message = await TranslatorService.TranslateAsync(
                "Terms accepted successfully.",
                "en",
                LanguageState.CurrentLanguage);

            // Ustawienie flagi, że regulamin jest już zaakceptowany również w aktualnym widoku.
            alreadyAccepted = true;
        }
        finally
        {
            // Odblokowanie przycisku po zakończeniu operacji zapisu.
            isSaving = false;
        }
    }

    // Czyszczenie subskrypcji zdarzenia, aby uniknąć wycieków pamięci.
    public void Dispose()
    {
        LanguageState.OnLanguageChanged -= HandleLanguageChanged;
    }
}