@page "/events"
@using Microsoft.AspNetCore.Authorization
@using EventManager.Data
@rendermode InteractiveServer
@inject IEventService EventService
@inject NavigationManager Navigation

@* Nagłówek strony z listą eventów *@
<h3>Lista Eventów</h3>

@* Jeśli dane jeszcze się ładują, pokazujemy komunikat *@
@if (events == null)
{
    <p>Ładowanie...</p>
}
@* Gdy lista została pobrana, wyświetlamy tabelę *@
else
{
    <table class="table">
        <thead>
            @* Nagłówki kolumn tabeli *@
            <tr>
                <th>ID</th>
                <th>Short Desc</th>
                <th>Opis</th>
                <th>Limit miejsc</th>
                <th>Aktualne miejsca</th>
                <th>Data</th>
                <th>Akcje</th>
            </tr>
        </thead>
        <tbody>
            @* Iteracja po wszystkich eventach i wyświetlenie ich w wierszach tabeli *@
            @foreach (var ev in events)
            {
                <tr>
                    <td>@ev.EVENT_ID</td>
                    <td>@ev.SHORT_DESC</td>
                    <td>@ev.DESCRIPTION</td>
                    <td>@ev.SPACE_LIMIT</td>
                    <td>@ev.CURR_SPACE</td>
                    <td>@ev.EVENT_DATE.ToString("yyyy-MM-dd")</td>
                    <td>
                        @* Przycisk prowadzący do strony ze szczegółami konkretnego eventu *@
                        <button class="btn btn-primary" @onclick="@(() => Navigation.NavigateTo($"/events/{ev.EVENT_ID}"))">
                            Szczegóły
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    @* Lista eventów pobrana z serwisu *@
    private List<Event>? events;

    @* Pobranie wszystkich eventów podczas inicjalizacji komponentu *@
    protected override async Task OnInitializedAsync()
    {
        events = await EventService.GetEventsAsync();
    }
}