@using Microsoft.AspNetCore.Components.Authorization @*potrzebne dla AuthorizeView itp.*@ 
@using System.Security.Claims @*potrzebne dla ClaimTypes.Name, ClaimTypes.Role*@
@inherits LayoutComponentBase //layout, a nie zwykły komponent

@inject AuthenticationStateProvider auth 
@inject NavigationManager nav

<div class="page">
    <div class="sidebar">
        <NavMenu /> @*menu boczne*@
    </div>

    <main>
        <div class="top-row px-4">
            <CascadingAuthenticationState> @*udostępnia stan logowania wszystkim komponentom wewnątrz, dlatego AuthorizeView wie, czy użytkownik jest zalogowany*@
                <AuthorizeView>
                    <NotAuthorized>
                        <NavLink class="nav-link" href="login">
                            <button class="btn btn-login">Login</button>
                        </NavLink>
                        <NavLink class="nav-link" href="register">
                            <button class="btn btn-login">Register</button>
                        </NavLink>
                    </NotAuthorized>
                </AuthorizeView>
                <AuthorizeView> @*renderuje zawartość tylko dla zalogowanych użytkowników, a jeśli użytkownik jest niezalogowany, nic nie pokaże*@
                    @*Hello @email - @role <a href="/logout" >Logout</a>*@
                    Hello @email - @role
                    <NavLink class="nav-link" href="logout">
                        <button class="btn btn-login">Logout</button>
                    </NavLink>
                </AuthorizeView>
            </CascadingAuthenticationState>
        </div>

        <article class="content px-4">
            @Body @*miejsce, gdzie renderują się wszystkie strony z @page*@
        </article>
    </main>
</div>

@*pokazuje się, gdy aplikacja Blazor Server straci połączenie lub wystąpi błąd*@
<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    public string email { get; set; }
    public string role { get; set; }

    protected override async Task OnInitializedAsync()
    {
        //pobranie stanu logowania
        var state = await auth.GetAuthenticationStateAsync();
        //pobranie użytkownika
        var user = state.User;

        //jeśli użytkownik jest zalogowany, email i rola pobierane są z Claims
        if (user.Identity.IsAuthenticated)
        {
            email = user.Claims.FirstOrDefault(x => x.Type == ClaimTypes.Name)?.Value;
            role = user.Claims.FirstOrDefault(x => x.Type == ClaimTypes.Role)?.Value;
        }
    }
}
