@page "/events/{Id}"
@using Microsoft.AspNetCore.Authorization
@using EventManager.Data
@rendermode InteractiveServer
@inject IEventService EventService
@inject NavigationManager Navigation
@inject UserService UserService

@if (ev == null)
{
    <div class="alert alert-info">Ładowanie szczegółów eventu...</div>
}
else if (string.IsNullOrEmpty(ev.EVENT_ID))
{
    <div class="alert alert-warning">Event nie znaleziony.</div>
}
else
{
    <div class="card">
        <div class="card-header">
            <h3>@ev.SHORT_DESC</h3>
        </div>
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-3">Opis:</dt>
                <dd class="col-sm-9">@ev.DESCRIPTION</dd>
                
                <dt class="col-sm-3">Limit miejsc:</dt>
                <dd class="col-sm-9">@ev.SPACE_LIMIT</dd>
                
                <dt class="col-sm-3">Zajęte miejsca:</dt>
                <dd class="col-sm-9">@ev.CURR_SPACE <span class="badge @(GetBadgeClass())">@GetOccupancyPercent()%</span></dd>
                
                <dt class="col-sm-3">Data eventu:</dt>
                <dd class="col-sm-9">@ev.EVENT_DATE.ToString("dd.MM.yyyy")</dd>
            </dl>
        </div>
        <div class="card-footer">
            <button class="btn btn-secondary me-2" @onclick="BackToList">Powrót do listy</button>
            @if (isJoined)
            {
                <button class="btn btn-outline-secondary me-2" @onclick="LeaveEvent">Opuść (już dołączyłeś)</button>
            }
            else if (ev?.CURR_SPACE < ev?.SPACE_LIMIT)
            {
                <button class="btn btn-success me-2" @onclick="JoinEvent">Dołącz do eventu</button>
            }
            else
            {
                <span class="badge bg-danger me-2">Brak wolnych miejsc</span>
            }
        </div>
    </div>
}

@code {
    [Parameter] public string Id { get; set; } = string.Empty;
    private Event? ev;
    private bool isJoined = false;
    private string currentUserId = string.Empty;  // Pobierz z autentykacji/contextu

    protected override async Task OnInitializedAsync()
    {
        ev = await EventService.GetEventAsync(Id);
        currentUserId = UserService.GetEmail(); // Pobierz email aktualnego użytkownika
        isJoined = await EventService.IsUserJoined(currentUserId, Id);
    }

    private string GetBadgeClass()
    {
        if (ev == null) return "";
        var percent = (double)ev.CURR_SPACE / ev.SPACE_LIMIT * 100;
        return percent > 90 ? "bg-danger" : percent > 70 ? "bg-warning" : "bg-success";
    }

    private string GetOccupancyPercent()
    {
        if (ev == null) return "";
        return Math.Round((double)ev.CURR_SPACE / ev.SPACE_LIMIT * 100).ToString();
    }

    private void BackToList() => Navigation.NavigateTo("/events");

    private async Task JoinEvent()
    {
        await EventService.JoinEventAsync(currentUserId, Id);
        isJoined = true;
        StateHasChanged();
        ev.CURR_SPACE++;  // Odśwież dane
    }

    private async Task LeaveEvent()
    {
        await EventService.LeaveEventAsync(currentUserId, Id);
        isJoined = false;
        StateHasChanged();
        ev.CURR_SPACE--;
    }
    
}