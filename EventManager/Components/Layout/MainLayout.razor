@using EventManager.Data
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@inherits LayoutComponentBase

@inject AuthenticationStateProvider auth
@inject LanguageStateService LanguageState
@inject IJSRuntime JS

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4 d-flex align-items-center justify-content-between">
            <div class="d-flex align-items-center gap-2">
                <label class="form-label mb-0">Language:</label>

                @* @onchange zamiast @bind:after — bardziej niezawodne *@
                <select class="form-select w-auto"
                        value="@selectedLanguage"
                        @onchange="OnLanguageChanged">
                    <option value="en">English</option>
                    <option value="pl">Polski</option>
                    <option value="de">Deutsch</option>
                    <option value="es">Español</option>
                    <option value="ru">Русский</option>
                    <option value="zh-Hans">中文</option>
                </select>
            </div>

            <CascadingAuthenticationState>
                <AuthorizeView>
                    <NotAuthorized>
                        <NavLink class="nav-link" href="login">
                            <button class="btn btn-login">Login</button>
                        </NavLink>
                        <NavLink class="nav-link" href="register">
                            <button class="btn btn-login">Register</button>
                        </NavLink>
                    </NotAuthorized>
                </AuthorizeView>

                <AuthorizeView>
                    Hello @email - @role
                    <NavLink class="nav-link" href="logout">
                        <button class="btn btn-login">Logout</button>
                    </NavLink>
                </AuthorizeView>
            </CascadingAuthenticationState>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    public string email { get; set; } = string.Empty;
    public string role { get; set; } = string.Empty;
    private string selectedLanguage = "en";

    protected override async Task OnInitializedAsync()
    {
        var state = await auth.GetAuthenticationStateAsync();
        var user = state.User;

        if (user.Identity?.IsAuthenticated == true)
        {
            email = user.Claims.FirstOrDefault(x => x.Type == ClaimTypes.Name)?.Value ?? string.Empty;
            role = user.Claims.FirstOrDefault(x => x.Type == ClaimTypes.Role)?.Value ?? string.Empty;
        }

        LanguageState.OnLanguageChanged += HandleLanguageChanged;
    }

    private bool _languageInitialized = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_languageInitialized) return;

        try
        {
            var saved = await JS.InvokeAsync<string?>("languageHelper.get");

            // Walidacja przed użyciem — odrzuć wszystko spoza listy
            var allowed = new[] { "en", "pl", "de", "es", "ru", "zh-Hans" };
            var lang = (saved != null && allowed.Contains(saved)) ? saved : "en";

            LanguageState.InitializeLanguage(lang);
            selectedLanguage = lang;
            _languageInitialized = true;
            StateHasChanged();
        }
        catch
        {
            // JS niedostępny podczas prerenderingu
        }
    }

    private async Task OnLanguageChanged(ChangeEventArgs e)
    {
        var lang = e.Value?.ToString();

        // Odrzuć wszystko co nie jest prawidłowym kodem języka
        var allowed = new[] { "en", "pl", "de", "es", "ru", "zh-Hans" };
        if (string.IsNullOrWhiteSpace(lang) || !allowed.Contains(lang))
            return;

        selectedLanguage = lang;
        await JS.InvokeVoidAsync("languageHelper.set", lang);
        LanguageState.SetLanguage(lang);
    }

    private void HandleLanguageChanged()
    {
        selectedLanguage = LanguageState.CurrentLanguage;
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        LanguageState.OnLanguageChanged -= HandleLanguageChanged;
    }
}