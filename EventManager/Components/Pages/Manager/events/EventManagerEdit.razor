@page "/eventsManagerEdit/{Id}"
@using EventManager.Data
@using Microsoft.AspNetCore.Authorization
@rendermode InteractiveServer
@inject IEventService EventService
@inject NavigationManager Navigation
@inject LanguageStateService LanguageState
@inject TranslatorService Translator

@attribute [Authorize(Roles = "Manager")]

@* Jeśli dane eventu jeszcze się ładują *@
@if (editEvent == null)
{
    <div class="alert alert-info">@t_Loading</div>
}
@* Formularz edycji wydarzenia *@
else
{
    <div class="card">
        <div class="card-header">
            <h3>@t_EditEvent</h3>
        </div>

        <div class="card-body">
            <EditForm Model="editEvent" OnValidSubmit="ShowConfirmPopup">
                <DataAnnotationsValidator />
                <ValidationSummary />

                @* ID eventu tylko do odczytu *@
                <div class="mb-3">
                    <label class="form-label">@t_EventId</label>
                    <InputText @bind-Value="editEvent.EVENT_ID"
                               class="form-control"
                               disabled />
                </div>

                @* Krótki opis wydarzenia *@
                <div class="mb-3">
                    <label class="form-label">@t_ShortDescription</label>
                    <InputText @bind-Value="editEvent.SHORT_DESC"
                               class="form-control" />
                </div>

                @* Opis wydarzenia *@
                <div class="mb-3">
                    <label class="form-label">@t_Description</label>
                    <InputTextArea @bind-Value="editEvent.DESCRIPTION"
                                   class="form-control" />
                </div>

                @* Limit miejsc *@
                <div class="mb-3">
                    <label class="form-label">@t_SeatLimit</label>
                    <InputNumber @bind-Value="editEvent.SPACE_LIMIT"
                                 class="form-control" />
                </div>

                @* Data wydarzenia *@
                <div class="mb-3">
                    <label class="form-label">@t_EventDate</label>
                    <InputDate @bind-Value="eventDate"
                               class="form-control" />
                </div>

                @* Przyciski formularza *@
                <button type="submit" class="btn btn-primary">
                    @t_Save
                </button>

                <button type="button"
                        class="btn btn-secondary ms-2"
                        @onclick="Cancel">
                    @t_Cancel
                </button>
            </EditForm>
        </div>
    </div>
}

@* Popup potwierdzający zapis zmian *@
@if (showConfirmPopup)
{
    <div class="popup-overlay">
        <div class="popup-card">
            <div class="popup-header">
                <div class="popup-title-wrap">
                    <span class="popup-icon">⚠️</span>
                    <span class="popup-title">@t_PopupTitle</span>
                </div>

                <button type="button"
                        class="popup-close"
                        @onclick="HideConfirmPopup">
                    ×
                </button>
            </div>

            <div class="popup-body">
                <p>@t_PopupBody</p>
            </div>

            <div class="popup-footer">
                <button class="btn btn-outline-secondary"
                        @onclick="HideConfirmPopup">
                    @t_Cancel
                </button>

                <button class="btn btn-primary"
                        @onclick="ConfirmSaveAsync">
                    @t_Save
                </button>
            </div>
        </div>
    </div>
}

@code {

    // Parametr pobierany z adresu URL
    [Parameter] public string Id { get; set; } = string.Empty;

    // Obiekt edytowanego wydarzenia
    private Event? editEvent;

    // Tymczasowa zmienna daty dla InputDate
    private DateTime eventDate = DateTime.Today;

    // Flaga widoczności popupu
    private bool showConfirmPopup = false;

    // Oryginalne teksty UI (EN)
    private const string Orig_Loading = "Loading event data...";
    private const string Orig_EditEvent = "Edit Event";
    private const string Orig_EventId = "Event ID (6 characters)";
    private const string Orig_ShortDescription = "Short description";
    private const string Orig_Description = "Description";
    private const string Orig_SeatLimit = "Seat limit";
    private const string Orig_EventDate = "Event date";
    private const string Orig_Save = "Save";
    private const string Orig_Cancel = "Cancel";
    private const string Orig_PopupTitle = "Confirm Changes";
    private const string Orig_PopupBody = "Are you sure you want to save the changes?";

    // Aktualne teksty UI
    private string t_Loading = Orig_Loading;
    private string t_EditEvent = Orig_EditEvent;
    private string t_EventId = Orig_EventId;
    private string t_ShortDescription = Orig_ShortDescription;
    private string t_Description = Orig_Description;
    private string t_SeatLimit = Orig_SeatLimit;
    private string t_EventDate = Orig_EventDate;
    private string t_Save = Orig_Save;
    private string t_Cancel = Orig_Cancel;
    private string t_PopupTitle = Orig_PopupTitle;
    private string t_PopupBody = Orig_PopupBody;

    // Pobranie danych wydarzenia po załadowaniu strony
    protected override async Task OnInitializedAsync()
    {
        editEvent = await EventService.GetEventAsync(Id);

        if (editEvent != null)
        {
            eventDate = editEvent.EVENT_DATE.ToDateTime(TimeOnly.MinValue);
        }

        // Subskrypcja zmiany języka
        LanguageState.OnLanguageChanged += OnLanguageChangedHandler;

        // Tłumaczenie przy wejściu na stronę
        await TranslateAll(LanguageState.CurrentLanguage);
    }

    // Obsługa zmiany języka
    private async void OnLanguageChangedHandler()
    {
        await TranslateAll(LanguageState.CurrentLanguage);
        await InvokeAsync(StateHasChanged);
    }

    // Tłumaczenie wszystkich tekstów UI
    private async Task TranslateAll(string lang)
    {
        // Jeśli język angielski — przywróć oryginały
        if (lang == "en")
        {
            t_Loading = Orig_Loading;
            t_EditEvent = Orig_EditEvent;
            t_EventId = Orig_EventId;
            t_ShortDescription = Orig_ShortDescription;
            t_Description = Orig_Description;
            t_SeatLimit = Orig_SeatLimit;
            t_EventDate = Orig_EventDate;
            t_Save = Orig_Save;
            t_Cancel = Orig_Cancel;
            t_PopupTitle = Orig_PopupTitle;
            t_PopupBody = Orig_PopupBody;

            return;
        }

        // Tłumaczenie równoległe wszystkich tekstów UI
        var ui = await Task.WhenAll(
            Translator.TranslateAsync(Orig_Loading, "en", lang),
            Translator.TranslateAsync(Orig_EditEvent, "en", lang),
            Translator.TranslateAsync(Orig_EventId, "en", lang),
            Translator.TranslateAsync(Orig_ShortDescription, "en", lang),
            Translator.TranslateAsync(Orig_Description, "en", lang),
            Translator.TranslateAsync(Orig_SeatLimit, "en", lang),
            Translator.TranslateAsync(Orig_EventDate, "en", lang),
            Translator.TranslateAsync(Orig_Save, "en", lang),
            Translator.TranslateAsync(Orig_Cancel, "en", lang),
            Translator.TranslateAsync(Orig_PopupTitle, "en", lang),
            Translator.TranslateAsync(Orig_PopupBody, "en", lang)
        );

        t_Loading = ui[0];
        t_EditEvent = ui[1];
        t_EventId = ui[2];
        t_ShortDescription = ui[3];
        t_Description = ui[4];
        t_SeatLimit = ui[5];
        t_EventDate = ui[6];
        t_Save = ui[7];
        t_Cancel = ui[8];
        t_PopupTitle = ui[9];
        t_PopupBody = ui[10];
    }

    // Pokazuje popup potwierdzający zapis
    private void ShowConfirmPopup()
    {
        showConfirmPopup = true;
    }

    // Ukrywa popup
    private void HideConfirmPopup()
    {
        showConfirmPopup = false;
    }

    // Zapisuje zmiany po potwierdzeniu
    private async Task ConfirmSaveAsync()
    {
        if (editEvent == null)
            return;

        editEvent.EVENT_DATE = DateOnly.FromDateTime(eventDate);

        await EventService.UpdateEventAsync(editEvent);

        Navigation.NavigateTo("/eventsManager");
    }

    // Anuluje edycję i wraca do listy
    private void Cancel()
    {
        Navigation.NavigateTo("/eventsManager");
    }

    // Usunięcie subskrypcji przy zamknięciu komponentu
    public void Dispose()
    {
        LanguageState.OnLanguageChanged -= OnLanguageChangedHandler;
    }
}